{
  "name": "travelflow",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm worktree:sync-env && pnpm flags:sync && vite",
    "dev:netlify": "pnpm worktree:sync-env && pnpm dlx netlify dev --port 8888 --target-port 5173",
    "worktree:install-hooks": "sh scripts/install-git-hooks.sh",
    "worktree:sync-env": "tsx scripts/sync-worktree-env.ts",
    "worktree:new": "tsx scripts/create-worktree.ts",
    "flags:sync": "tsx scripts/sync-flagpack-assets.ts",
    "i18n:validate": "node scripts/validate-i18n.mjs",
    "supabase:validate": "node scripts/validate-supabase-docs.mjs",
    "supabase:check-main-sync": "node scripts/check-supabase-main-sync.mjs",
    "updates:validate": "node scripts/validate-updates.mjs",
    "toasts:validate": "node scripts/validate-toast-usage.mjs",
    "storage:validate": "tsx scripts/validate-storage-registry.ts",
    "plans:validate-sync": "tsx scripts/validate-plan-sync.mjs",
    "plans:generate-seed": "tsx scripts/generate-plan-seed.mjs",
    "updates:next-version": "node scripts/next-release-version.mjs",
    "blog:validate": "node scripts/validate-blog.mjs",
    "edge:validate": "node scripts/validate-edge-functions.mjs",
    "og:site:build": "tsx scripts/build-site-og-static-images.ts",
    "og:site:build:full": "SITE_OG_STATIC_TARGET_SCOPE=full pnpm og:site:build",
    "og:site:validate": "tsx scripts/validate-site-og-static-manifest.ts",
    "og:site:validate:full": "SITE_OG_STATIC_TARGET_SCOPE=full pnpm og:site:validate",
    "sitemap:generate": "node scripts/generate-sitemap.mjs",
    "inspirations:images:jobs": "tsx scripts/build-inspiration-image-batch.ts",
    "build:images": "tsx scripts/build-inspiration-images.ts",
    "inspirations:images:optimize": "tsx scripts/build-inspiration-images.ts --skip-generation",
    "blog:images:jobs": "tsx scripts/build-blog-image-batch.ts",
    "build:blog-images": "tsx scripts/build-blog-images.ts",
    "blog:images:optimize": "tsx scripts/build-blog-images.ts --skip-generation",
    "build:image-placeholders": "tsx scripts/build-image-placeholders.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:core": "vitest run --coverage --reporter=default",
    "test:e2e": "playwright test",
    "test:e2e:offline": "playwright test e2e/offline-resilience.spec.ts",
    "release:prepare": "pnpm build:blog-images && pnpm build",
    "build": "pnpm test:core && pnpm flags:sync && pnpm inspirations:images:optimize && pnpm blog:images:optimize && pnpm build:image-placeholders && pnpm og:site:build && pnpm og:site:validate && pnpm i18n:validate && pnpm supabase:validate && pnpm plans:validate-sync && pnpm updates:validate && pnpm toasts:validate && pnpm storage:validate && pnpm blog:validate && pnpm edge:validate && pnpm sitemap:generate && vite build && node scripts/prerender-routes.mjs",
    "build:netlify": "pnpm flags:sync && pnpm inspirations:images:optimize && pnpm blog:images:optimize && pnpm build:image-placeholders && pnpm og:site:build && pnpm og:site:validate && pnpm i18n:validate && pnpm supabase:validate && pnpm plans:validate-sync && pnpm updates:validate && pnpm toasts:validate && pnpm storage:validate && pnpm blog:validate && pnpm edge:validate && pnpm sitemap:generate && vite build && node scripts/prerender-routes.mjs",
    "preview": "vite preview",
    "maps:generate": "tsx scripts/generate-trip-maps.ts",
    "airports:generate": "tsx scripts/generate-airports-reference.ts",
    "countries:search:generate": "tsx scripts/generate-country-search-metadata.ts",
    "ai:eval": "tsx scripts/run-ai-eval.ts",
    "ai:eval:ci": "tsx scripts/run-ai-eval.ts --ci",
    "ai:eval:security": "tsx scripts/run-ai-eval.ts --pack security",
    "ai:eval:security:ci": "tsx scripts/run-ai-eval.ts --pack security --ci",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@google/genai": "1.45.0",
    "@number-flow/react": "^0.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@pierre/diffs": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@supabase/supabase-js": "^2.97.0",
    "@tremor/react": "^3.18.7",
    "@types/google.maps": "^3.58.1",
    "@vis.gl/react-google-maps": "1.7.1",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "2.0.0",
    "flagpack": "^1.0.5",
    "framer-motion": "^12.34.3",
    "gradient-shimmer": "0.1.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-icu": "^2.4.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.575.0",
    "lz-string": "1.5.0",
    "mapbox-gl": "^3.20.0",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6.7.0",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.4.3",
    "react": "18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "18.3.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "rough-notation": "^0.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.182.0",
    "vaul": "^0.9.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "critical": "^8.0.0",
    "jsdom": "^28.1.0",
    "promptfoo": "0.121.2",
    "react-doctor": "^0.2.9",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
