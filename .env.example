# Get your Gemini API Key here: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Canonical public site URL used for sitemap/SEO absolute URLs
SITE_URL=https://travelflowapp.netlify.app
# Server-side Gemini key (preferred for edge API routes)
GEMINI_API_KEY=your_server_gemini_api_key_here
# Server-side provider keys (used by future provider adapters / internal benchmarking)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Internal benchmark/admin edge API guard key (temporary until role-based auth ships)
TF_ADMIN_API_KEY=replace_with_a_long_random_secret

# Async AI generation rollout flags
AI_GENERATION_ASYNC_WORKER_ENABLED=false
VITE_AI_GENERATION_ASYNC_FLOW_CLASSIC_ENABLED=false
VITE_AI_GENERATION_ASYNC_FLOW_WIZARD_ENABLED=false
VITE_AI_GENERATION_ASYNC_FLOW_SURPRISE_ENABLED=false

# Get your Google Maps API Key here: https://console.cloud.google.com/
# Ensure "Maps JavaScript API" and "Places API" are enabled.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Paddle billing (web checkout + webhook sync)
VITE_PADDLE_CHECKOUT_ENABLED=false
PADDLE_ENV=sandbox
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here
PADDLE_PRICE_ID_TIER_MID=pri_xxxxx
PADDLE_PRICE_ID_TIER_PREMIUM=
# Optional allowlisted checkout domain override, e.g. https://pay.travelflow.app/checkout
PADDLE_CHECKOUT_DOMAIN=
# Optional webhook timestamp tolerance in seconds (default: 300)
PADDLE_WEBHOOK_MAX_AGE_SECONDS=300
# Optional webhook sync mode:
# - full: verify + persist to Supabase (default)
# - verify_only: verify signature + payload, skip Supabase writes (useful before DB migration is applied)
PADDLE_WEBHOOK_SYNC_MODE=full

# Umami browser tracker (optional, loaded only after "Accept all")
VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
VITE_UMAMI_WEBSITE_ID=your_umami_website_id_here

# Navigation warmup & predictive prefetching
# Defaults: enabled in production when unset.
VITE_NAV_PREFETCH_ENABLED=true
VITE_SPECULATION_RULES_ENABLED=true
VITE_PREFETCH_DEBUG=false

# Umami backend database (set on your Umami deployment, never exposed to browser bundles)
# Supabase-hosted Umami usually needs pooled + direct URLs.
DATABASE_URL=postgres://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_DATABASE_URL=postgres://postgres.your-project:password@db.your-project.supabase.co:5432/postgres

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=CLIENT_KEY_FROM_OPENID
